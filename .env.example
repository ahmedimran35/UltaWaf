# UltraShield WAF Environment Template
# Copy this to .env and fill in your values

# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_USER=waf
POSTGRES_PASSWORD=changeme_generate_strong_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ultrashield_waf

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_generate_strong_password

# ============================================
# SECURITY SETTINGS
# ============================================
SECRET_KEY=changeme_run_openssl_rand_hex_32
AI_ENCRYPTION_KEY=changeme_run_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================
# WAF CONFIGURATION
# ============================================
WAF_ENABLED=true
BLOCK_MODE=true
LOG_ALL_REQUESTS=true
MAX_REQUEST_SIZE=10485760

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ============================================
# DDOS PROTECTION
# ============================================
DDoS_THRESHOLD=1000
DDoS_WINDOW=60

# ============================================
# ML ENGINE
# ============================================
ML_ENABLED=true
ML_ANOMALY_THRESHOLD=0.75

# ============================================
# APPLICATION SETTINGS
# ============================================
DEBUG=false
LOG_LEVEL=INFO

# ============================================
# OPTIONS
# ============================================
# ENABLE_2FA=true
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_FROM=alerts@yourdomain.com
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...
# DISCORD_WEBHOOK_URL=https://discord.com/api/...